  } else {
    curBoard = profile.board;
    localStorage.setItem('es_board', profile.board);
    updateBoardPill();
  }
}

function saveStudentProfile(){
  const name = document.getElementById('ssName').value.trim();
  const board = document.getElementById('ssBoard').value;
  if(!name){ alert('कृपया अपना नाम लिखें!'); return; }
  const profile = {name, board, date: new Date().toISOString()};
  localStorage.setItem('es_student', JSON.stringify(profile));
  curBoard = board;
  localStorage.setItem('es_board', board);
  document.getElementById('studentSetup').style.display='none';
