const pages = ['home','subject','pyq','doubts','quiz','notes'];
function navTo(page, el){
  const currentPage = document.querySelector('.page.active');
  const currentIndex = pages.indexOf(currentPage ? currentPage.id.replace('page','').toLowerCase() : 'home');
  const newIndex = pages.indexOf(page);
  const direction = newIndex > currentIndex ? 'slide-in-right' : 'slide-in-left';
  
  document.querySelectorAll('.ni').forEach(n=>n.classList.remove('active'));
  el.classList.add('active');
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  history.pushState({page}, '', '#'+page);
  
  let newPage;
  if(page==='home'){ newPage=document.getElementById('pageHome'); renderHome(); }
  else if(page==='subject'){ newPage=document.getElementById('pageSubject'); showAllSubjects(); }
  else if(page==='pyq'){ newPage=document.getElementById('pagePYQ'); pyqYearFilter='all'; pyqSubjFilter='all'; renderPYQ(); buildPYQSubjTabs(); }
  else if(page==='doubts'){ newPage=document.getElementById('pageDoubts'); }
  else if(page==='quiz'){ newPage=document.getElementById('pageQuiz'); renderQuizList(); }
  else if(page==='notes'){ newPage=document.getElementById('pageNotes'); renderNotes(); }
  
  if(newPage){
    newPage.classList.add('active', direction);
    setTimeout(()=>newPage.classList.remove('slide-in-right','slide-in-left'), 300);
  }
}

function goHome(){
  document.querySelectorAll('.ni').forEach(n=>n.classList.remove('active'));
  document.querySelector('.ni').classList.add('active');
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.getElementById('pageHome').classList.add('active');
  history.pushState({page:'home'}, '', '#home');
}

