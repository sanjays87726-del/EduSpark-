function listenLiveClass(){
  db.collection('_config').doc('liveClass').onSnapshot(doc=>{
    if(doc.exists){
      const data = doc.data();
      renderLiveBanner(data);
    }
  }, ()=>{});
}

function renderLiveBanner(data){
  const sec = document.getElementById('liveBannerSec');
  if(!sec) return;
  if(!data || data.status==='off'){ sec.style.display='none'; return; }
  if(data.board && data.board!=='ALL' && data.board!==curBoard){ sec.style.display='none'; return; }
  sec.style.display='block';
  document.getElementById('liveTag').textContent = data.status==='live' ? '🔴 LIVE NOW' : '⏰ UPCOMING';
  document.getElementById('liveTitle').textContent = data.title || 'Live Class';
  document.getElementById('liveTime').textContent = data.timeText || '';
  window._liveClassLink = data.link || '';
}

function openLiveClass(){
  if(window._liveClassLink) playVideo(window._liveClassLink);
}

function showToast(msg){
  const t=document.getElementById('toast');
  t.textContent=msg; t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),2500);
}
