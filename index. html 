function saveNote(){
  const title=document.getElementById('noteTitle').value.trim();
  const text=document.getElementById('noteText').value.trim();
  if(!text){ showToast('❌ Note खाली है!'); return; }
  const notes=JSON.parse(localStorage.getItem('es_notes')||'[]');
  notes.push({id:Date.now(),title:title||'Untitled',text,date:new Date().toISOString()});
  localStorage.setItem('es_notes',JSON.stringify(notes));
  document.getElementById('noteTitle').value='';
  document.getElementById('noteText').value='';
  showToast('✅ Note save हो गया!'); renderNotes();
}
function renderNotes(){
  const notes=JSON.parse(localStorage.getItem('es_notes')||'[]').reverse();
  document.getElementById('notesList').innerHTML=notes.length
    ? notes.map(n=>`
        <div class="note-item">
          <div style="display:flex;justify-content:space-between;align-items:center;">
            <div style="font-size:13px;font-weight:700;color:var(--navy);">${n.title}</div>
            <button onclick="delNote(${n.id})" style="background:#FEE2E2;color:var(--red);border:none;padding:4px 8px;border-radius:6px;font-size:11px;cursor:pointer;">🗑</button>
          </div>
          <div style="font-size:12px;color:var(--g600);margin-top:6px;line-height:1.6;">${n.text}</div>
          <div style="font-size:10px;color:var(--g400);margin-top:4px;">${new Date(n.date).toLocaleDateString('hi-IN')}</div>
        </div>`).join('')
    : '<div class="empty"><div class="ei">📒</div><p>अभी कोई note नहीं।</p></div>';
}
function delNote(id){
  localStorage.setItem('es_notes',JSON.stringify(JSON.parse(localStorage.getItem('es_notes')||'[]').filter(n=>n.id!==id)));
  renderNotes(); showToast('🗑 Delete हो गया');
}

