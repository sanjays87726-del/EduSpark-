function buildPYQSubjTabs(){
  const subs = [...new Set(allPYQ.filter(p=>p.board===curBoard).map(p=>p.subject))];
  const subData = SUBJECTS[curBoard]||[];
  let html = '<div class="type-tab active" onclick="filterPYQSubj(\'all\',this)">📚 All</div>';
  subs.forEach(sid=>{
    const s = subData.find(x=>x.id===sid);
    if(s) html += `<div class="type-tab" onclick="filterPYQSubj('${sid}',this)">${s.icon} ${s.name}</div>`;
  });
  document.getElementById('pyqSubjTabs').innerHTML = html;
}

function filterPYQ(year, el){
  pyqYearFilter = year;
  document.querySelectorAll('#pyqBoardTabs .type-tab').forEach(t=>t.classList.remove('active'));
  if(el) el.classList.add('active');
  renderPYQ();
}

function filterPYQExam(examType, el){
  pyqExamFilter = examType;
  document.querySelectorAll('#pyqExamTabs .type-tab').forEach(t=>t.classList.remove('active'));
  if(el) el.classList.add('active');
  renderPYQ();
}

function filterPYQSubj(subj, el){
  pyqSubjFilter = subj;
  document.querySelectorAll('#pyqSubjTabs .type-tab').forEach(t=>t.classList.remove('active'));
  if(el) el.classList.add('active');
  renderPYQ();
}

function renderPYQ(){

let items = allPYQ.filter(
  p => String(p.board).toLowerCase() === String(curBoard).toLowerCase()
);
  if(pyqYearFilter!=='all') items = items.filter(p=>String(p.year)===pyqYearFilter);
  if(pyqSubjFilter!=='all') items = items.filter(p=>p.subject===pyqSubjFilter);
  if(pyqExamFilter!=='all') items = items.filter(p=>p.examType===pyqExamFilter);
  const subData = SUBJECTS[curBoard]||[];

  if(document.getElementById('pyqCount'))
    document.getElementById('pyqCount').textContent = items.length+' PYQ Papers';
  if(document.getElementById('pyqBoard'))
    document.getElementById('pyqBoard').textContent = curBoard.replace('-',' Class ');

  // Tiles hide/show based on filter
  const tilesGrid = document.querySelector('#pyqList div[style*="grid"]');
  const tilesTitle = document.querySelector('#pyqList .sec-t');
  if(pyqYearFilter!=='all'||pyqSubjFilter!=='all'){
    if(tilesGrid) tilesGrid.style.display='none';
    if(tilesTitle) tilesTitle.style.display='none';
  } else {
    if(tilesGrid) tilesGrid.style.display='';
    if(tilesTitle) tilesTitle.style.display='';
  }

  const listEl = document.getElementById('pyqFilteredList');
  if(!listEl) return;
  listEl.innerHTML = items.length
    ? items.map(p=>{
        const sub = subData.find(s=>s.id===p.subject);
        return `<div class="pyq-item">
          <span class="pyq-year">${p.year}</span>
          <span class="pyq-board-tag">${(p.board || '').replace('-',' ')}</span>
          <div class="pyq-title">📜 ${p.title || 'Untitled PYQ'}</div>
          <div class="pyq-sub">${sub?sub.icon+' '+sub.name:''} ${p.desc?'• '+p.desc:''}</div>
          <div class="pyq-footer">
            <span style="font-size:10px;color:var(--g400);">${p.examType||'Board Exam'}</span>
            ${p.link?`<button class="pyq-dl" onclick="window.open('${p.link}','_blank')">📥 Download</button>`:'<span style="font-size:11px;color:var(--g400);">Link coming soon</span>'}
          </div>
        </div>`;
      }).join('')
    : pyqYearFilter!=='all'
      ? `<div class="empty"><div class="ei">📜</div><p>${pyqYearFilter} mein koi PYQ nahi hai।</p></div>`
      : '';
}

