function submitDoubt(){
  const text=document.getElementById('dText').value.trim();
  if(!text){ showToast('❌ Doubt खाली है!'); return; }
  db.collection('doubts').add({
    board:curBoard,subject:document.getElementById('dSubj').value,
    topic:document.getElementById('dTopic').value.trim(),text,
    name:document.getElementById('dName').value.trim()||'Anonymous',
    date:new Date().toISOString(),status:'pending',answer:'',deviceId:DEVICE_ID,
  }).then(()=>{
    document.getElementById('dTopic').value='';
    document.getElementById('dText').value='';
    document.getElementById('dName').value='';
    showToast('✅ Doubt submit हो गया!');
  }).catch(()=>showToast('❌ Error! दोबारा कोशिश करें।'));
}
function renderDoubts(doubts){
  const subs = SUBJECTS[curBoard] || [];

  const filtered = (doubts || []).filter(d =>
    d.board === curBoard &&
    (d.deviceId === DEVICE_ID || !d.deviceId)
  );

  document.getElementById('doubtsList').innerHTML = filtered.length
    ? filtered.map(d => {
        const sub = subs.find(s => s.id === d.subject);

        return `
        <div class="doubt-item">
          <div class="d-meta">
            ${sub ? sub.name : '?'} • ${d.topic || 'General'} • ${d.name}
          </div>
          <div class="d-q">❓ ${d.text}</div>
          ${d.answer ? `<div class="d-ans">✅ ${d.answer}</div>` : ''}
          <span class="d-st ${d.status === 'answered' ? 'st-a' : 'st-p'}">
            ${d.status === 'answered' ? '✅ Answered' : '⏳ Pending'}
          </span>
        </div>`;
      }).join('')
    : '<div class="empty"><div class="ei">💬</div><p>अभी कोई doubt नहीं।</p></div>';
}

