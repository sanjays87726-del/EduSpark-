// QUIZ
// ══════════════════════════════════════════
function renderQuizList(){
  exitQuiz();
  const list=allQuizzes.filter(q=>q.board===curBoard);
  document.getElementById('quizListSec').innerHTML=list.length
    ? list.map((q,i)=>`
        <div class="qz-card">
          <div class="qzc-t">${q.title}</div>
          <div class="qzc-s">${q.subject||''}</div>
          <div class="qzc-meta">
            <span class="qzc-tag">📝 ${q.questions.length} Questions</span>
            <span class="qzc-tag">⏱ ~${q.questions.length*30}s</span>
          </div>
          <button class="start-btn" onclick="startQuiz(${i})">▶ Start Quiz</button>
        </div>`).join('')
    : '<div class="empty"><div class="ei">🧩</div><p>अभी कोई quiz नहीं।</p></div>';
}
function startQuiz(idx){
  const list=allQuizzes.filter(q=>q.board===curBoard);
  curQuiz=list[idx]; curQ=0; score=0; answered=false;
  document.getElementById('quizListSec').style.display='none';
  document.getElementById('quizActive').style.display='block';
  document.getElementById('quizResult').style.display='none';
  showQ();
}
function showQ(){
  if(!curQuiz||curQ>=curQuiz.questions.length){ showResult(); return; }
  const q=curQuiz.questions[curQ], total=curQuiz.questions.length;
  answered=false;
  document.getElementById('qNum').textContent=`Question ${curQ+1} of ${total}`;
  document.getElementById('qFill').style.width=((curQ/total)*100)+'%';
  document.getElementById('qText').textContent=q.q;
  document.getElementById('qOpts').innerHTML=q.options.map((o,i)=>
    `<div class="q-opt" onclick="selOpt(this,${i},${q.ans})">${String.fromCharCode(65+i)}. ${o}</div>`).join('');
  document.getElementById('qNext').textContent=curQ===total-1?'Result ✓':'अगला →';
}
function selOpt(el,idx,ans){
  if(answered)return; answered=true;
  document.querySelectorAll('.q-opt').forEach(o=>o.classList.remove('sel','corr','wrong'));
  el.classList.add(idx===ans?'corr':'wrong');
  document.querySelectorAll('.q-opt')[ans].classList.add('corr');
  if(idx===ans)score++;
}
function nextQ(){ curQ++; showQ(); }
function showResult(){
  document.getElementById('quizActive').style.display='none';
  document.getElementById('quizResult').style.display='block';
  const total=curQuiz.questions.length, pct=Math.round((score/total)*100);
  document.getElementById('rEmoji').textContent=pct>=80?'🏆':pct>=50?'👍':'💪';
  document.getElementById('rScore').textContent=`${score}/${total} (${pct}%)`;
  document.getElementById('rMsg').textContent=pct>=80?'शानदार! बेहतरीन Performance!':pct>=50?'अच्छा! और practice करें!':'हिम्मत रखें, आप कर सकते हैं!';
}
function exitQuiz(){
  curQuiz=null;
  if(document.getElementById('quizListSec')) document.getElementById('quizListSec').style.display='block';
  if(document.getElementById('quizActive')) document.getElementById('quizActive').style.display='none';
  if(document.getElementById('quizResult')) document.getElementById('quizResult').style.display='none';
}

