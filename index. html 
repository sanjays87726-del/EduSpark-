// CONTENT HTML
// ══════════════════════════════════════════
function cHTML(c){
  const T={pdf:{i:'📄',bg:'ci-pdf',b:'bdg-pdf',l:'PDF'},video:{i:'🎥',bg:'ci-video',b:'bdg-video',l:'Video'},dpp:{i:'📗',bg:'ci-dpp',b:'bdg-dpp',l:'DPP'},note:{i:'🗒️',bg:'ci-note',b:'bdg-note',l:'Note'}};
  const t=T[c.type]||T.note;
  const isNew=c.date&&(Date.now()-new Date(c.date).getTime())<7*24*60*60*1000;
  let click='';
  if(c.link){
    if(c.type==='video'){
      click=`onclick="playVideo('${c.link}')"`;
    } else {
      click=`onclick="window.open('${c.link}','_blank')"`;
    }
  }
  return `<div class="cnt-item" ${click}>
    <div class="cnt-ic ${t.bg}">${t.i}</div>
    <div class="cnt-info">
      <h4>${c.title}</h4>
      <p>${c.desc||c.chapter||''}</p>
      <span class="bdg ${t.b}">${t.l}</span>${isNew?'<span class="bdg bdg-new">NEW</span>':''}
    </div>
    <span style="font-size:18px;color:var(--g400);">${c.link?'🔗':'📄'}</span>
  </div>`;
}

